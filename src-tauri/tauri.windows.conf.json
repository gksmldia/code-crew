{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "code-crew",
        "label": "main",
        "width": 500,
        "height": 320,
        "x": 0,
        "y": 600,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "shadow": true,
        "dragDropEnabled": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "targets": ["nsis"],
    "resources": {
      "binaries/code-crew-hook.exe": "code-crew-hook.exe"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
