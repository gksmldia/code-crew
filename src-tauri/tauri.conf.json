{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "code-crew",
  "version": "0.1.4",
  "identifier": "com.dorothy.codecrew",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "code-crew",
        "label": "main",
        "width": 500,
        "height": 320,
        "x": 0,
        "y": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDRTYxRUM4MTAzQkE1QzYKUldUR3BUc1F5QjdtakFBWFlHT0M1dnVMK0pTMjM5MFBNaXpLUFlEUGVldWNOQ0syQ3ExNUwwckMK",
      "endpoints": [
        "https://github.com/gksmldia/code-crew/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
